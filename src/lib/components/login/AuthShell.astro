---
const { title = '', description = '' } = Astro.props;
---

<section class="min-h-screen bg-background text-foreground">
	<div class="relative mx-auto flex min-h-screen w-full items-center justify-center overflow-hidden px-5 py-4 sm:px-8">
		<div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,hsl(0_0%_0%)_0%,hsl(0_0%_0%)_100%)]"></div>
		<div class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,hsl(0_0%_0%)_0%,hsl(0_0%_0%)_58%,hsl(154_100%_70%/0.04)_100%)]"></div>
		<div class="beam beam-primary"></div>
		<div class="beam beam-secondary"></div>
		<div class="grid-fade"></div>
		<div class="aurora-vignette"></div>

		<div class="relative w-full max-w-5xl">
			{(title || description) && (
				<div class="space-y-3">
					{title && <h1 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">{title}</h1>}
					{description && (
						<p class="max-w-lg text-base leading-7 text-muted-foreground">
							{description}
						</p>
					)}
				</div>
			)}

			<div class={title || description ? 'mt-8' : ''}>
				<slot />
			</div>
		</div>
	</div>
</section>

<style is:inline>
	.beam {
		position: absolute;
		left: 50%;
		width: 120vmax;
		height: 18vmax;
		border-radius: 9999px;
		filter: blur(42px);
		transform: translateX(-50%);
		background: linear-gradient(
			90deg,
			transparent 0%,
			hsl(154 95% 67% / 0.02) 12%,
			hsl(154 100% 70% / 0.18) 34%,
			hsl(162 100% 70% / 0.12) 52%,
			hsl(154 95% 67% / 0.05) 72%,
			transparent 100%
		);
	}

	.beam-primary {
		top: 10%;
		transform: translateX(-50%) rotate(-18deg);
		opacity: 0.85;
	}

	.beam-secondary {
		bottom: 12%;
		transform: translateX(-50%) rotate(12deg);
		opacity: 0.5;
		background: linear-gradient(
			90deg,
			transparent 0%,
			hsl(154 95% 67% / 0.01) 20%,
			hsl(154 100% 72% / 0.1) 42%,
			hsl(166 100% 70% / 0.08) 58%,
			hsl(154 95% 67% / 0.03) 76%,
			transparent 100%
		);
	}

	.grid-fade {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(hsl(0 0% 100% / 0.035) 1px, transparent 1px),
			linear-gradient(90deg, hsl(0 0% 100% / 0.035) 1px, transparent 1px);
		background-size: 72px 72px;
		mask-image: linear-gradient(180deg, transparent 0%, black 18%, black 72%, transparent 100%);
		opacity: 0.18;
	}

	.aurora-vignette {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at center, transparent 0%, transparent 46%, hsl(0 0% 0% / 0.62) 100%);
	}
</style>
