---
const { eyebrow = '', title = '', description = '', class: className = '' } = Astro.props;
---

<section class:list={['space-y-4', className]}>
	{(eyebrow || title || description) && (
		<div class="space-y-2">
			{eyebrow && (
				<p class="m-0 text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-muted-foreground">
					{eyebrow}
				</p>
			)}
			{title && <h2 class="m-0 text-lg font-semibold tracking-tight text-foreground">{title}</h2>}
			{description && <p class="m-0 text-sm leading-6 text-muted-foreground">{description}</p>}
		</div>
	)}

	<slot />
</section>
