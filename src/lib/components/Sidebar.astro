---
import CalendarDays from 'lucide-svelte/icons/calendar-days'
import FileText from 'lucide-svelte/icons/file-text'
import FlaskConical from 'lucide-svelte/icons/flask-conical'
import Grid2x2 from 'lucide-svelte/icons/grid-2x2'
import House from 'lucide-svelte/icons/house'
import ListTodo from 'lucide-svelte/icons/list-todo'
import Menu from 'lucide-svelte/icons/menu'
import School from 'lucide-svelte/icons/school'
import X from 'lucide-svelte/icons/x'
import SidebarProfileMenu from '$lib/components/SidebarProfileMenu.astro'

const { currentPath = '/', student } = Astro.props

const links = [
	{ href: '/', label: 'Home', icon: House },
	{ href: '/grades', label: 'Grades', icon: Grid2x2 },
	{ href: '/assignments', label: 'Assignments', icon: ListTodo },
	{ href: '/attendance', label: 'Attendance', icon: CalendarDays },
	{ href: '/documents', label: 'Documents', icon: FileText },
	{ href: '/tests', label: 'Tests', icon: FlaskConical },
	{ href: '/school', label: 'School', icon: School }
]

const studentName = student?.FormattedName ?? 'Student'
const studentInitials = studentName
	.split(' ')
	.filter(Boolean)
	.map((part) => part[0])
	.slice(0, 2)
	.join('')
	.toUpperCase()
const studentSchool = student?.Address?.CurrentSchool ?? student?.CurrentSchool ?? ''
const studentPhoto = student?.Address?.Photo ?? student?.Photo ?? ''
const studentId = student?.PermID ?? student?.ID ?? student?.StudentID ?? 'Unknown'
const currentLabel = links.find((link) => link.href === currentPath)?.label ?? 'Menu'
---

<aside class="relative hidden md:block">
	<div class="group fixed inset-y-4 left-4 z-50 w-[5.5rem] transition-[width] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] hover:w-[16rem]">
		<div class="flex h-[calc(100vh-2rem)] flex-col overflow-visible rounded-[2rem] border border-border bg-card p-4 shadow-2xl shadow-black/30 backdrop-blur">
			<div class="relative h-[4.15rem] w-full py-3">
				<div class="absolute inset-x-0 top-3 flex justify-center">
					<div class="flex items-center transition-[gap] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] gap-0 group-hover:gap-3">
						<div class="h-11 w-11 shrink-0 overflow-hidden">
							<img
								src="/favicon-64.png?v=2"
								alt="GradeGoblin"
								class="block h-11 w-11 object-contain"
							/>
						</div>
						<div class="min-w-0 overflow-hidden transition-[max-width,opacity,transform] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] max-w-0 -translate-x-1 opacity-0 group-hover:max-w-[9.25rem] group-hover:translate-x-0 group-hover:opacity-100">
							<p class="truncate text-sm font-semibold tracking-tight">GradeGoblin</p>
							<p class="truncate text-[0.7rem] text-muted-foreground">Student dashboard</p>
						</div>
					</div>
				</div>
			</div>

			<div class="mt-6 min-h-0 flex-1 overflow-y-auto overflow-x-hidden pr-1">
				<nav class="flex min-h-full w-full flex-col justify-center gap-2">
					{links.map((link) => (
						<a
							href={link.href}
							class={`flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition-colors ${
								currentPath === link.href ? 'bg-white/[0.08] text-white' : 'text-muted-foreground hover:bg-white/[0.05] hover:text-white'
							}`}
							data-nav-link
						>
							<link.icon class="size-5 shrink-0" />
							<span class="overflow-hidden whitespace-nowrap transition-[max-width,opacity,transform] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] max-w-0 -translate-x-1 opacity-0 group-hover:max-w-[9rem] group-hover:translate-x-0 group-hover:opacity-100">
								{link.label}
							</span>
						</a>
					))}
				</nav>
			</div>

			<div class="pt-4">
				<SidebarProfileMenu
					studentName={studentName}
					studentSchool={studentSchool}
					studentInitials={studentInitials}
					studentPhoto={studentPhoto}
					studentId={studentId}
				/>
			</div>
		</div>
	</div>
</aside>

<div class="fixed inset-x-4 top-4 z-50 flex items-center justify-between gap-3 md:hidden">
	<button
		type="button"
		id="mobile-nav-open"
		class="inline-flex size-12 items-center justify-center rounded-2xl border border-border/70 bg-card/90 text-foreground shadow-xl shadow-black/20 backdrop-blur"
		aria-expanded="false"
		aria-controls="mobile-nav-drawer"
		aria-label="Open navigation"
	>
		<Menu class="size-5" />
	</button>
	<div data-mobile-nav-title class="min-w-0 truncate rounded-2xl border border-border/70 bg-card/75 px-3 py-2 text-sm font-medium text-foreground shadow-lg shadow-black/15 backdrop-blur">
		{currentLabel}
	</div>
</div>

<div id="mobile-nav-shell" class="pointer-events-none fixed inset-0 z-[60] md:hidden" aria-hidden="true">
	<div id="mobile-nav-backdrop" class="absolute inset-0 bg-black/55 opacity-0 transition-opacity duration-200"></div>
	<aside
		id="mobile-nav-drawer"
		class="absolute inset-y-0 left-0 flex w-[min(20rem,88vw)] -translate-x-full flex-col border-r border-border bg-card p-4 shadow-2xl shadow-black/40 transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]"
	>
		<div class="relative flex flex-col items-center justify-center pt-2 text-center">
			<button
				type="button"
				id="mobile-nav-close"
				class="absolute right-0 top-0 inline-flex size-10 items-center justify-center rounded-2xl text-muted-foreground transition-colors hover:bg-white/[0.05] hover:text-white"
				aria-label="Close navigation"
			>
				<X class="size-5" />
			</button>
			<div class="h-11 w-11 shrink-0 overflow-hidden">
				<img
					src="/favicon-64.png?v=2"
					alt="GradeGoblin"
					class="block h-11 w-11 object-contain"
				/>
			</div>
			<div class="mt-3">
				<p class="text-sm font-semibold tracking-tight">GradeGoblin</p>
				<p class="text-[0.7rem] text-muted-foreground">Student dashboard</p>
			</div>
		</div>

		<nav class="mt-6 flex flex-1 flex-col gap-2">
			{links.map((link) => (
				<a
					href={link.href}
					class={`flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition-colors ${
						currentPath === link.href ? 'bg-white/[0.08] text-white' : 'text-muted-foreground hover:bg-white/[0.05] hover:text-white'
					}`}
					aria-current={currentPath === link.href ? 'page' : undefined}
					data-nav-link
				>
					<link.icon class="size-5 shrink-0" />
					<span>{link.label}</span>
				</a>
			))}
		</nav>

		<SidebarProfileMenu
			studentName={studentName}
			studentSchool={studentSchool}
			studentInitials={studentInitials}
			studentPhoto={studentPhoto}
			studentId={studentId}
			mobile={true}
		/>
	</aside>
</div>

<script is:inline>
	const normalizePathLabel = (path) => {
		if (path === '/') return 'Home';
		const segment = path.split('/').filter(Boolean).at(-1) ?? 'Menu';
		return segment.charAt(0).toUpperCase() + segment.slice(1);
	};

	let lastMobileNavTrigger = null;

	const getMobileNavEls = () => ({
		title: document.querySelector('[data-mobile-nav-title]'),
		shell: document.getElementById('mobile-nav-shell'),
		drawer: document.getElementById('mobile-nav-drawer'),
		backdrop: document.getElementById('mobile-nav-backdrop'),
		open: document.getElementById('mobile-nav-open')
	});

	const syncMobileNavTitle = () => {
		const { title } = getMobileNavEls();
		if (title) title.textContent = normalizePathLabel(window.location.pathname);
	};

	const setMobileNavOpen = (open) => {
		const { shell, drawer, backdrop, open: openButton } = getMobileNavEls();
		if (!shell || !drawer || !backdrop || !openButton) return;
		shell.classList.toggle('pointer-events-none', !open);
		drawer.classList.toggle('-translate-x-full', !open);
		backdrop.classList.toggle('opacity-0', !open);
		openButton.setAttribute('aria-expanded', open ? 'true' : 'false');
		if (open) {
			shell.removeAttribute('aria-hidden');
			shell.inert = false;
			window.setTimeout(() => {
				const closeButton = document.getElementById('mobile-nav-close');
				if (closeButton instanceof HTMLElement) closeButton.focus();
			}, 20);
		} else {
			shell.setAttribute('aria-hidden', 'true');
			shell.inert = true;
			window.setTimeout(() => {
				if (lastMobileNavTrigger instanceof HTMLElement) {
					lastMobileNavTrigger.focus();
				}
			}, 20);
		}
		document.body.classList.toggle('overflow-hidden', open);
	};

	const closeMobileNav = () => setMobileNavOpen(false);
	syncMobileNavTitle();
	const initialShell = document.getElementById('mobile-nav-shell');
	if (initialShell) initialShell.inert = true;

	window.addEventListener('pageshow', closeMobileNav);
	window.addEventListener('astro:page-load', () => {
		syncMobileNavTitle();
		lastMobileNavTrigger = null;
		const shell = document.getElementById('mobile-nav-shell');
		if (shell) shell.inert = true;
		closeMobileNav();
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeMobileNav();
	});

	document.addEventListener('click', (event) => {
		const openTrigger = event.target.closest('#mobile-nav-open');
		if (openTrigger) {
			lastMobileNavTrigger = openTrigger;
			setMobileNavOpen(true);
			return;
		}

		const closeTrigger = event.target.closest('#mobile-nav-close, #mobile-nav-backdrop');
		if (closeTrigger) {
			closeMobileNav();
			return;
		}

		const link = event.target.closest('#mobile-nav-drawer a[href]');
		if (link) closeMobileNav();
	});
</script>
