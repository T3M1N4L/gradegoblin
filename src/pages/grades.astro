---
import DashboardLayout from '$layouts/DashboardLayout.astro'
import { loadDashboard, readSelectedPeriod } from '$lib/server/dashboard'

const resolveCoursePeriod = (course, fallbackIndex) => {
	const raw = course?.Period ?? course?._Period
	const parsed = Number(raw)
	return Number.isFinite(parsed) && parsed > 0 ? parsed : fallbackIndex + 1
}

const toNumber = (value) => {
	const parsed = Number(String(value ?? '').replace('%', ''))
	return Number.isFinite(parsed) ? parsed : null
}

const getGradeAccent = (value) => {
	const score = toNumber(value)
	if (score == null) return 'rgb(244, 244, 245)'
	if (score >= 90) return 'rgb(74, 222, 128)'
	if (score >= 80) return 'rgb(190, 242, 100)'
	if (score >= 70) return 'rgb(251, 191, 36)'
	if (score >= 60) return 'rgb(251, 146, 60)'
	return 'rgb(248, 113, 113)'
}

if (!Astro.locals.user) return Astro.redirect('/login')
const period = readSelectedPeriod(Astro.cookies)
const data = await loadDashboard(Astro.locals, period)
const courses = data.gradebook?.Courses?.Course ?? []
const missingAssignments = courses.reduce((sum, course) => sum + Number(course.missingCount ?? 0), 0)
const assignmentTotal = courses.reduce((sum, course) => sum + Number(course.assignmentCount ?? 0), 0)
const stats = [
	{ label: 'Courses', value: String(courses.length), style: '' },
	{ label: 'Missing assignments', value: String(missingAssignments), style: missingAssignments > 0 ? 'color: hsl(0 72% 60%);' : '' },
	{ label: 'Tracked assignments', value: String(assignmentTotal), style: '' },
	{ label: 'Average', value: data.selected?.average ?? '-', style: `color: ${getGradeAccent(data.selected?.average)};` }
]
---
<DashboardLayout title="Grades" currentPath="/grades" student={data.student} periodDates={data.periodDates} selectedPeriod={data.selectedPeriod} showPeriodSelector={true}>
	<div class="grid grid-cols-4 gap-2 sm:gap-4">
		{stats.map((stat) => (
			<section class="min-w-0 rounded-[1.25rem] border border-border/70 bg-card/60 p-3 sm:rounded-[1.75rem] sm:p-5">
				<p class="text-[0.7rem] leading-tight text-muted-foreground sm:text-sm">{stat.label}</p>
				<p class="mt-2 truncate font-mono text-lg font-semibold tracking-tight sm:mt-3 sm:text-3xl" style={stat.style}>{stat.value}</p>
			</section>
		))}
	</div>

	<section class="mt-6 rounded-[2rem] border border-border/70 bg-card/60" transition:name="gradebook-panel">
		<div class="p-6">
			<h2 class="text-xl font-semibold">{data.selected?.ReportingPeriod?.GradePeriod ?? 'Selected reporting period'}</h2>
		</div>
		<div class="overflow-x-auto px-6 pb-6">
			<table class="w-full text-left text-sm">
				<thead class="text-muted-foreground">
					<tr>
						<th class="px-4 pb-3 font-medium">Course</th>
						<th class="px-4 pb-3 font-medium">Teacher</th>
						<th class="px-4 pb-3 font-medium">Assignments</th>
						<th class="px-4 pb-3 text-right font-medium">Grade</th>
					</tr>
				</thead>
				<tbody>
					{courses.map((course, i) => {
						const coursePeriod = resolveCoursePeriod(course, i)
						return (
							<tr
								class="cursor-pointer border-t border-border/60 transition-colors hover:bg-background/40"
								data-row-link
								data-href={`/period/${coursePeriod}`}
								tabindex="0"
								onclick={`window.location.assign('/period/${coursePeriod}')`}
							>
								<td class="px-4 py-4">
									<div class="px-2 py-1" transition:name={`course-card-${data.selectedPeriod}-${coursePeriod}`}>
										<div class="font-medium">{course.Title}</div>
										<div class="mt-1 text-xs text-muted-foreground">
											{course.CourseID ?? course._CourseID ?? 'Course'} • Period {course.Period ?? course._Period ?? '-'} • Room {course.Room ?? course._Room ?? '-'}
										</div>
									</div>
								</td>
								<td class="px-4 py-4 text-muted-foreground">
									<div>{course.Staff ?? course._Staff ?? 'Teacher unavailable'}</div>
									<div class="mt-1 text-xs">{course.StaffEMail ?? course._StaffEMail ?? ''}</div>
								</td>
								<td class="px-4 py-4">
									<div class="font-mono text-sm text-muted-foreground">{course.assignmentCount ?? 0}</div>
									{course.missingCount > 0 && <div class="font-mono text-xs text-destructive">{course.missingCount} missing</div>}
								</td>
								<td class="px-4 py-4 text-right">
									<div
										class="text-3xl font-semibold tracking-tight"
										style={`color: ${course.color ?? getGradeAccent(course.scorePercent ?? course.score)};`}
									>
										{course.scoreString}
									</div>
									<div class="font-mono text-base text-muted-foreground">{course.score}</div>
								</td>
							</tr>
						)
					})}
				</tbody>
			</table>
		</div>
	</section>
</DashboardLayout>
